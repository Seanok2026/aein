{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/prices", "dest": "/api/prices.js" },
    { "src": "/api/rss", "dest": "/api/rss.js" },
    { "src": "/.netlify/functions/rss", "dest": "/api/rss.js" },
    { "src": "/(.*)", "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    }
  ]
}
